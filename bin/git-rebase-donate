#!/usr/bin/env bash

set -euo pipefail

__grd_log() {
  echo "[git-rebase-donate] $*"
}

__grd_die() {
  echo "git-rebase-donate: $*" >&2
  exit 1
}

__grd_require_clean_worktree() {
  local repo_path=${1:-.}
  if ! git -C "$repo_path" diff --quiet --no-ext-diff || ! git -C "$repo_path" diff --cached --quiet --no-ext-diff; then
    __grd_die "working tree must be clean: ${repo_path}"
  fi
}

__grd_require_branch() {
  local branch
  branch=$(git branch --show-current)
  [[ -n "$branch" ]] || __grd_die "must be on a branch"
  printf '%s\n' "$branch"
}

__grd_branch_worktree_path() {
  local target_branch="refs/heads/$1"
  local current_worktree=""
  local branch=""
  local line=""
  while IFS= read -r line; do
    case "$line" in
      worktree\ *)
        current_worktree=${line#worktree }
        branch=""
        ;;
      branch\ *)
        branch=${line#branch }
        if [[ "$branch" == "$target_branch" ]]; then
          printf '%s\n' "$current_worktree"
          return 0
        fi
        ;;
    esac
  done < <(git worktree list --porcelain)
  return 1
}

__grd_rebase_in_progress() {
  local repo_path=$1
  local rebase_path
  rebase_path=$(git -C "$repo_path" rev-parse --git-path rebase-merge)
  [[ -d "$rebase_path" ]] && return 0
  rebase_path=$(git -C "$repo_path" rev-parse --git-path rebase-apply)
  [[ -d "$rebase_path" ]]
}

__grd_operation_is_empty() {
  local repo_path=$1
  local operation=$2

  # An otherwise-empty stop has no unmerged paths and nothing staged. Keep any
  # real conflict (or other failure) paused for the user to resolve.
  [[ -z "$(git -C "$repo_path" ls-files --unmerged)" ]] || return 1
  git -C "$repo_path" diff --cached --quiet --no-ext-diff || return 1

  case "$operation" in
    cherry-pick)
      git -C "$repo_path" rev-parse --verify -q CHERRY_PICK_HEAD >/dev/null
      ;;
    rebase)
      __grd_rebase_in_progress "$repo_path"
      ;;
    *)
      return 1
      ;;
  esac
}

__grd_run_skipping_empty() {
  local repo_path=$1
  local operation=$2
  shift 2

  if git -C "$repo_path" "$@"; then
    return 0
  fi

  while __grd_operation_is_empty "$repo_path" "$operation"; do
    __grd_log "Skipping otherwise-empty ${operation} commit"
    if git -C "$repo_path" "$operation" --skip; then
      return 0
    fi
  done

  return 1
}

main() {
  local prefix=${GIT_REBASE_DONATE_PREFIX:-}
  local upstream=${GIT_REBASE_DONATE_UPSTREAM:-}
  [[ -n "$prefix" ]] || __grd_die "GIT_REBASE_DONATE_PREFIX must be set"
  [[ -n "$upstream" ]] || __grd_die "GIT_REBASE_DONATE_UPSTREAM must be set"

  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || __grd_die "not inside a git repository"
  __grd_require_clean_worktree

  local original_branch
  original_branch=$(__grd_require_branch)
  [[ "$original_branch" != "$upstream" ]] || __grd_die "current branch must not be ${upstream}"

  local current_worktree
  current_worktree=$(git rev-parse --show-toplevel)
  git rev-parse --verify "$upstream" >/dev/null 2>&1 || __grd_die "upstream branch ${upstream} does not exist locally"

  local -a donated_commits=()
  local commit subject
  while IFS= read -r commit; do
    [[ -n "$commit" ]] || continue
    subject=$(git log -1 --format=%s "$commit")
    if [[ "$subject" != "$prefix"* ]]; then
      donated_commits+=("$commit")
    fi
  done < <(git rev-list --reverse "${upstream}..${original_branch}")

  __grd_log "Original branch: ${original_branch}"
  __grd_log "Upstream branch: ${upstream}"
  __grd_log "Found ${#donated_commits[@]} commit(s) to donate"

  local upstream_worktree
  upstream_worktree=$(__grd_branch_worktree_path "$upstream" || true)
  if [[ -z "$upstream_worktree" ]]; then
    upstream_worktree=$current_worktree
    git switch "$upstream"
  else
    __grd_require_clean_worktree "$upstream_worktree"
    __grd_log "Using upstream worktree: ${upstream_worktree}"
  fi

  if ((${#donated_commits[@]} > 0)); then
    # Cherry-pick in original order so the donated series lands on upstream unchanged.
    __grd_run_skipping_empty "$upstream_worktree" cherry-pick cherry-pick "${donated_commits[@]}"
  fi

  __grd_run_skipping_empty "$upstream_worktree" rebase pull --rebase
  git -C "$upstream_worktree" push

  if [[ "$upstream_worktree" == "$current_worktree" ]]; then
    git switch "$original_branch"
  fi
  # Rebasing after the donate/push step lets Git drop duplicate patches from the topic branch.
  __grd_run_skipping_empty "$current_worktree" rebase rebase "$upstream"
}

main "$@"
