{
  "manifest_version": 3,
  "name": "HN Vibe Expander",
  "version": "0.1.0",
  "description": "Expands very short Hacker News comments into longer, thoughtful versions using OpenAI.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://news.ycombinator.com/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://news.ycombinator.com/item?id=*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "HN Vibe Expander"
  }
}
