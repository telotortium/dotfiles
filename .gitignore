.cask/
dist/

# Flycheck
flycheck_*.el

# server auth directory
/server/

# projectiles files
.projectile

# directory configuration
.dir-locals.el

# network security
/network-security.data

# .local is usually an install directory for other packages, so no permanent configs and the like to track.
/.local/

# misc/build is where I download Git repos/build tarballs. Nothing permanent there.
/misc/build/

