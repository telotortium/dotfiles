# IMPORTANT: Before adding or reordering rules, read the
# "HOME-REPOSITORY SAFETY POLICY" section near the end of this file. Rule
# order is security-sensitive because this repository covers the entire home
# directory and uses a default-deny allowlist.

.CFUserTextEncoding
.DS_Store
/.Trash/**
/crontab-local-backup

# Credentials
/.config/dbxcli/auth.json

# User data, not for tracking
