{
    "global": { "show_in_menu_bar": false },
    "profiles": [
        {
            "complex_modifications": {
                "parameters": { "basic.to_if_alone_timeout_milliseconds": 400 },
                "rules": [
                    {
                        "description": "Disable Karabiner-Elements with Fn+Control+Option+Command+Z",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "z",
                                    "modifiers": { "mandatory": ["left_control", "left_command", "left_option"] }
                                },
                                "to": [{ "shell_command": "osascript ~/Documents/karabiner-restart.scpt" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Change Caps Lock to Ctrl, Esc if alone",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "key_code": "left_control",
                                        "lazy": true
                                    }
                                ],
                                "to_if_alone": [{ "key_code": "escape" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Change Left Cmd+Right Cmd+Esc to caps lock",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "escape",
                                    "simultaneous": [
                                        { "key_code": "left_command" },
                                        { "key_code": "right_command" }
                                    ]
                                },
                                "to": [{ "key_code": "escape" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Volume for Lenovo External",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "identifiers": [
                                            {
                                                "description": "Lenovo Traditional USB Keyboard",
